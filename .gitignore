node_modules/
.pnpm-store/

# build artifacts
**/.next/
**/dist/
**/.turbo/
**/tsconfig.tsbuildinfo
*.tsbuildinfo

# env / secrets — only `.env.example` is committed
.env
.env.local
.env.*.local
.env_old
.env_todelete
.env.bak

