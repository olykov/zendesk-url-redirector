**/data/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# logs / coverage
*.log
npm-debug.log*
pnpm-debug.log*
coverage/

# OS / IDE
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# misc
.cache/

# Override common global gitignore patterns (e.g. `~/.gitignore_global`
# inherited from Python templates) that would otherwise block our source.
!apps/frontend/src/lib/
!apps/frontend/src/lib/**
