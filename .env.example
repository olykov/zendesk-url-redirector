# ============================================================
# REQUIRED — fill these before first run
# ============================================================

# Zendesk API access. Subdomain is the part before .zendesk.com
# (e.g. for "acme.zendesk.com" use "acme").
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# Random secret used to sign session cookies. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Postgres credentials. The compose file uses these to provision the database
# and to build DATABASE_URL automatically — you don't need to write the URL.
POSTGRES_USER=redirector
POSTGRES_PASSWORD=redirector
POSTGRES_DB=redirector


# ============================================================
# Built-in admin login (defaults work — change before exposing)
# ============================================================

BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=redirector


# ============================================================
# Optional polish
# ============================================================

# Public Help Center URL. When set, the backend HEAD-probes every redirect_from
# on this host periodically and the UI shows a green/yellow/red status dot per
# rule. Also adds clickable "open in browser" links in the UI (frontend reads
# the same value via NEXT_PUBLIC_HELP_CENTER_URL — kept identical for simplicity).
# HELP_CENTER_URL=https://support.example.com
# NEXT_PUBLIC_HELP_CENTER_URL=https://support.example.com

# Health-check tuning (defaults shown). Only matters if HELP_CENTER_URL is set.
#   - HEALTH_INTERVAL_SECONDS:       seconds between full batches. Hard minimum
#                                    is 1 hour (3600); lower values are silently
#                                    clamped to 3600 with a warning in the log.
#   - HEALTH_CHECK_CONCURRENCY:      parallel HEAD requests (1-20, default 2)
#   - HEALTH_CHECK_REQUEST_DELAY_MS: per-worker pause between requests (default 300)
#   - HEALTH_CHECK_TIMEOUT_MS:       per-request timeout (1000-30000, default 8000)
#   - HEALTH_CHECK_USER_AGENT:       identifies us in Help Center access logs

# HEALTH_INTERVAL_SECONDS=3600
# HEALTH_CHECK_CONCURRENCY=2
# HEALTH_CHECK_REQUEST_DELAY_MS=300
# HEALTH_CHECK_TIMEOUT_MS=8000
# HEALTH_CHECK_USER_AGENT=zendesk-redirector-health/0.1 (+self-hosted)

# Small label on the login screen footer.
# NEXT_PUBLIC_INSTANCE_LABEL=

# Override the SSO button text on the login page (default: "Continue with Keycloak").
# Useful when your SSO is rebranded internally (e.g. "Continue with Acme ID").
# NEXT_PUBLIC_OPENID_BUTTON_LABEL=Continue with Keycloak

# Stable secret for basic-auth bearer tokens. If unset, AUTH_SECRET is reused
# (recommended). Set explicitly only if backend and frontend must not share it.
# BASIC_AUTH_JWT_SECRET=

# Multi-brand Zendesk accounts only — pin new rules to a specific brand.
# ZENDESK_DEFAULT_BRAND_ID=


# ============================================================
# Keycloak SSO (optional) — fill ALL four to enable
# ============================================================

# KEYCLOAK_ISSUER=https://keycloak.example.com/realms/<realm>
# KEYCLOAK_CLIENT_ID=zendesk-redirector
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_AUDIENCE=zendesk-redirector


# ============================================================
# Networking (defaults are fine for local dev and docker compose)
# ============================================================

NEXTAUTH_URL=http://localhost:3000

# Used only when running backend outside docker compose. Inside compose this is
# built from POSTGRES_* automatically and passed to the backend container.
# DATABASE_URL=postgres://redirector:redirector@localhost:5432/redirector
